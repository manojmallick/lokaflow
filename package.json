{
  "name": "lokaflow",
  "version": "1.0.0",
  "description": "LokaFlow Engine Monolithic Orchestrator",
  "private": true,
  "scripts": {
    "postinstall": "husky install",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\" \"apps/*/src/**/*.{ts,tsx}\" --ignore-unknown",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\" \"apps/*/src/**/*.{ts,tsx}\" --ignore-unknown",
    "lint": "eslint \"packages/*/src/**/*.ts\" \"apps/*/src/**/*.{ts,tsx}\"",
    "test": "pnpm -r run test",
    "test:cov": "vitest run --coverage",
    "typecheck": "pnpm -r run typecheck",
    "build": "pnpm -r run build",
    "start": "pnpm --filter @lokaflow/cli start"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.1",
    "eslint": "^9.0.0",
    "husky": "^8.0.3",
    "prettier": "^3.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}